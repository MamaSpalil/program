inp_struc_major= input.int(200, "Major Structure Lookback", minval=10, maxval=200, group=group_mtf)
inp_pivot_left = input.int(4, "Minor Structure: Левое плечо (Вес)",  minval=1, maxval=50, group=group_mtf)
inp_pivot_right= input.int(1,  "Minor Structure: Правое плечо (Подтверждение)", minval=1, maxval=50, group=group_mtf)
use_trend   = input.bool(true,  "Фильтр по тренду (EMA)", group=group_mtf)
