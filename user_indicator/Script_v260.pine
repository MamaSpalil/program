inp_vol_len  = input.int(40,   "Период сглаживания объема (SMA)", minval=10, maxval=200, group=group_math)
inp_eff_len  = input.int(5,    "Длина FER (Efficiency)",          minval=2,  maxval=20,  group=group_math)
inp_z_min    = input.float(0.85,"Минимальный Z-Score",            minval=0.1,maxval=2.0, step=0.1, group=group_math)
inp_z_max    = input.float(5.0, "Z-Score насыщения",              minval=1.0,maxval=10.0,step=0.1, group=group_math)
