// @version=6
strategy("Trading Fluppy ENGINE",
     overlay=true,
     initial_capital=1000,
     default_qty_type=strategy.cash,
     default_qty_value=1000,
     max_labels_count=500,
     max_boxes_count=500,
     max_lines_count=500,
     max_bars_back=5000,
     calc_on_every_tick=true,
     process_orders_on_close=true)

// ==========================================
// БЛОК 0: ГЛОБАЛЬНЫЕ КОНСТАНТЫ БЕЗОПАСНОСТИ
// ==========================================
// Жёсткий потолок для ЛЮБОГО обращения к series[offset]
// max_bars_back резервирует 4999, последний доступный индекс = 4998
int MAX_BUFF     = 4999   // для max_bars_back()
int BUF_FLAGS    = 1500    // для флагов/счётчиков, не требующих глубокой истории
int MAX_OFFSET   = 4998   // максимальный безопасный series[offset]
int MAX_OFFSET_2 = 4997   // для функций требующих [offset+1]
int MAX_OFFSET_3 = 4996   // для функций требующих [offset+2]

// V258: Штраф к Score если число паттернов < p_multi_pattern_min (адаптируется по ТФ)
float MULTI_PATTERN_PENALTY = 0.85

// Универсальный clamp: гарантирует что offset в [0, ceil]
f_clamp(int val, int ceil) => math.max(0, math.min(val, ceil))

// V260: Сокращённый f_mt(x) для экономии токенов
f_mt(float v) => str.tostring(v, format.mintick)

// V264: Сокращённый f_ts(x) для экономии токенов (простой str.tostring)
f_ts(float v) => str.tostring(v)

// V260: Score to tier string helper
f_tier(float sc) => sc >= 100 ? "BEST" : sc >= 80 ? "STRONG" : sc >= 40 ? "NORMAL" : "PIVOT"

// V260: Score emoji helper
f_emoji(float sc) => sc >= 120 ? "🔥" : sc >= 100 ? "💎" : sc >= 80 ? "🟢" : sc >= 40 ? "⚪" : "⚓"

// V254: Безопасная конкатенация строк — не превышает лимит Pine Script (40960 символов)
MAX_STR_LEN = 4096 * 10 - 100  // 40860 — оставляем запас до лимита 40960
TRUNCATE_SUFFIX = "\n…(truncated)"
TRUNCATE_SUFFIX_LEN = 15
f_safe_append(string base, string suffix) =>
    string result = base
    if str.length(base) + str.length(suffix) > MAX_STR_LEN
        result := str.substring(base, 0, math.max(0, MAX_STR_LEN - str.length(suffix) - TRUNCATE_SUFFIX_LEN)) + TRUNCATE_SUFFIX + suffix
    else
        result := base + suffix
    result

// ==========================================
// БЛОК 1: НАСТРОЙКИ (INPUTS)
// ==========================================

type RejectedInfo
    int     origin_idx
    bool    is_bull
    float   score
    string  reasons
    int     created_at

group_auto = "🤖 Auto-Tuner & Logic"
tuning_mode = input.string("Auto-Adaptive", title="Режим работы", options=["Auto-Adaptive", "Manual (User Control)"], group=group_auto)
auto_info   = input.bool(true, title="Показывать информационную панель", group=group_auto)

group_hist  = "⏳ History Horizon"
hist_mode   = input.string("Auto-Scale", title="Режим ограничения истории", options=["Auto-Scale", "Fixed Limit"], group=group_hist)
inp_hist_bars = input.int(4800, title="Базовая глубина истории (бары)", minval=500, maxval=4999, group=group_hist)

group_score = "⭐ Dynamic Scoring (Efficiency Engine)"
use_score      = input.bool(true, "Фильтровать зоны по минимальному Score", group=group_score)
min_score_gate = input.int(45, "Минимальный суммарный Score (0–150)", minval=0, maxval=150, group=group_score)
chopcount_int  = input.int(10, "Минимальный ChopCount", minval=4, maxval=20, group=group_score)
w_zscore  = input.float(25.0, "Вес: Z-Score",                     minval=0, maxval=100, step=0.5, group=group_score)
w_vol     = input.float(15.0, "Вес: Volume",                      minval=0, maxval=100, step=0.5, group=group_score)
w_trend   = input.float(15.0, "Вес: Trend Alignment",             minval=0, maxval=100, step=0.5, group=group_score)
w_sweep   = input.float(15.0, "Вес: Sweep / Liquidity Grab",      minval=0, maxval=100, step=0.5, group=group_score)
w_eff     = input.float(15.0, "Вес: Efficiency (FER)",            minval=0, maxval=100, step=0.5, group=group_score)
w_bonus   = input.float(15.0, "Вес: PA Patterns (Брейк, Поглощение)", minval=0, maxval=100, step=0.5, group=group_score)

float _sum_w = w_zscore + w_vol + w_trend + w_sweep + w_eff + w_bonus
float _safe_sum = math.max(_sum_w, 0.001)
float w_zscore_norm  = w_zscore  / _safe_sum * 100.0
float w_vol_norm     = w_vol     / _safe_sum * 100.0
float w_trend_norm   = w_trend   / _safe_sum * 100.0
float w_sweep_norm   = w_sweep   / _safe_sum * 100.0
float w_eff_norm     = w_eff     / _safe_sum * 100.0
float w_bonus_norm   = w_bonus   / _safe_sum * 100.0

group_stoch = "📊 Stochastic Engine"
stoch_min_val = input.int(3,  "Мин. зон для прогноза",      minval=3,  maxval=50,  group=group_stoch)
stoch_max_val = input.int(30, "Зон для 100% уверенности",   minval=10, maxval=100, group=group_stoch)

group_sess = "🌍 Global Sessions"
show_sess  = input.bool(false, "Показывать сессионные боксы", group=group_sess)
sess_timezone = input.string("America/New_York", title="Таймзона сессий", options=["America/New_York","Europe/London","Asia/Tokyo","UTC"], group=group_sess)
sess_asia_t = input.session("1900-0300", "Asia (Tokyo time)", group=group_sess)
c_asia      = input.color(color.new(color.blue, 90), "Asia Color", group=group_sess)
sess_lond_t = input.session("0300-1130", "London", group=group_sess)
c_lond      = input.color(color.new(color.orange, 90), "London Color", group=group_sess)
sess_ny_t   = input.session("0930-1600", "New York", group=group_sess)
c_ny        = input.color(color.new(color.purple, 90), "NY Color", group=group_sess)
sess_ovrl_t = input.session("0930-1130", "London-NY Overlap", group=group_sess)
c_ovrl      = input.color(color.new(color.red, 85), "Overlap Color", group=group_sess)

group_bt   = "🗓️ Бэктест"
use_date   = input.bool(false, "Включить фильтр по датам", group=group_bt)
t_start    = input.time(timestamp("01 Jan 2024 00:00 UTC"), "Начало периода", group=group_bt)
t_end      = input.time(timestamp("01 Jan 2030 00:00 UTC"), "Конец периода",  group=group_bt)

