{
    "name": "cryptotrader/web-version-php",
    "description": "CryptoTrader Web Version - PHP Backend with MSSQL 2012",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-sqlsrv": "*",
        "ext-pdo_sqlsrv": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "CryptoTrader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CryptoTrader\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=PSR12 src/",
        "phpcbf": "phpcbf --standard=PSR12 src/"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
