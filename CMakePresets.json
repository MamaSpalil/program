{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vcpkg",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        }
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release (VS 2019)",
      "description": "MSVC Release build with vcpkg dependencies (Visual Studio 2019)",
      "inherits": "vcpkg",
      "generator": "Visual Studio 16 2019",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/vs2019-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug (VS 2019)",
      "description": "MSVC Debug build with vcpkg dependencies (Visual Studio 2019)",
      "inherits": "vcpkg",
      "generator": "Visual Studio 16 2019",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/vs2019-x64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-release-vs2022",
      "displayName": "Windows x64 Release (VS 2022)",
      "description": "MSVC Release build for Visual Studio 2022",
      "inherits": "vcpkg",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/vs2022-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-x64-debug-vs2022",
      "displayName": "Windows x64 Debug (VS 2022)",
      "description": "MSVC Debug build for Visual Studio 2022",
      "inherits": "vcpkg",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/vs2022-x64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "description": "GCC/Clang Release build",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "description": "GCC/Clang Debug build",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "displayName": "Windows Release (VS 2019)",
      "configurePreset": "windows-x64-release",
      "configuration": "Release"
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug (VS 2019)",
      "configurePreset": "windows-x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-release-vs2022",
      "displayName": "Windows Release (VS 2022)",
      "configurePreset": "windows-x64-release-vs2022",
      "configuration": "Release"
    },
    {
      "name": "windows-debug-vs2022",
      "displayName": "Windows Debug (VS 2022)",
      "configurePreset": "windows-x64-debug-vs2022",
      "configuration": "Debug"
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "configurePreset": "linux-release"
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "configurePreset": "linux-debug"
    }
  ]
}
