{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vcpkg",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        }
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "description": "MSVC Release build with vcpkg dependencies",
      "inherits": "vcpkg",
      "generator": "Visual Studio 16 2019",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/vs2019-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "Torch_DIR": {
          "type": "PATH",
          "value": "C:/libs/libtorch/share/cmake/Torch"
        },
        "XGBoost_DIR": {
          "type": "PATH",
          "value": "C:/libs/xgboost/lib/cmake/XGBoost"
        }
      }
    },
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "description": "MSVC Debug build with vcpkg dependencies",
      "inherits": "vcpkg",
      "generator": "Visual Studio 16 2019",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/vs2019-x64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "Torch_DIR": {
          "type": "PATH",
          "value": "C:/libs/libtorch/share/cmake/Torch"
        },
        "XGBoost_DIR": {
          "type": "PATH",
          "value": "C:/libs/xgboost/lib/cmake/XGBoost"
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "configurePreset": "windows-x64-release",
      "configuration": "Release"
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "configurePreset": "windows-x64-debug",
      "configuration": "Debug"
    }
  ]
}